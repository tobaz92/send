# Bloquer tout accès direct au storage
Require all denied

# Alternative pour anciennes versions Apache
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

# Désactiver l'exécution PHP
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# Bloquer tous les types de fichiers
<FilesMatch ".*">
    Require all denied
</FilesMatch>
